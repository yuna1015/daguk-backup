{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "jsx-a11y",
    "import"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "dist-electron/**",
    ".expo/**",
    "packages/web/public/runable.js"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  }
}
